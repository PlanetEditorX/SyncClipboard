{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SyncClipboard Server",
      "type": "debugpy",
      "request": "launch",
      "module": "server.run",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "SyncClipboard Client",
      "type": "debugpy",
      "request": "launch",
      "module": "client.run",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ],
  "compounds": [
    {
      "name": "Server + Client",
      "configurations": ["SyncClipboard Server", "SyncClipboard Client"]
    }
  ]
}
